---
import { getEntry } from 'astro:content';

const base = import.meta.env.BASE_URL;
const infos = await getEntry('infos', 'infos');
const telephone = infos?.data.telephone ?? '';
const email = infos?.data.email ?? '';
const instagram = infos?.data.instagram ?? '';
const facebook = infos?.data.facebook ?? '';
const placeDesLibraires = infos?.data.placeDesLibraires ?? '';
const year = new Date().getFullYear();
---
<footer>
  <img
    aria-hidden="true"
    src={`${base}assets/feather.png`}
    alt=""
    class="footer-feather"
  />
  <div class="footer-inner">
    <img src={`${base}assets/logo-escalire.png`} alt="Librairie Escalire" class="footer-logo" />
    <p class="footer-tagline">Librairie indépendante à Escalquens — Sicoval</p>
    <div class="footer-links">
      <a href={instagram} target="_blank" rel="noopener">Instagram</a>
      <a href={facebook} target="_blank" rel="noopener">Facebook</a>
      <a href={placeDesLibraires} target="_blank" rel="noopener">Place des Libraires</a>
      <a href="https://escalire.fr/MentionsLegales.html" target="_blank" rel="noopener">Mentions légales</a>
    </div>
    <p class="footer-copyright">© {year} Librairie Escalire — {telephone} — {email}</p>
    <fieldset class="anim-setting">
      <legend>Animations</legend>
      <label><input type="radio" name="intensite" value="immersif" checked /> immersif</label>
      <label><input type="radio" name="intensite" value="equilibre" /> équilibré</label>
      <label><input type="radio" name="intensite" value="discret" /> discret</label>
    </fieldset>
  </div>
</footer>
<style>
  footer {
    position: relative;
    background: var(--sky);
    padding: 70px 28px 44px;
    overflow: hidden;
  }
  .footer-feather {
    position: absolute;
    right: 5%;
    bottom: -34px;
    width: 140px;
    height: auto;
    transform: rotate(26deg);
    opacity: 0.9;
  }
  .footer-inner {
    position: relative;
    max-width: 1140px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 26px;
    text-align: center;
  }
  .footer-logo { height: 64px; }
  .footer-tagline {
    margin: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 20px;
    color: var(--night);
  }
  .footer-links {
    display: flex;
    gap: 22px;
    flex-wrap: wrap;
    justify-content: center;
    font-family: var(--font-body);
    font-size: 16px;
  }
  .footer-links a {
    color: var(--ink);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .footer-links a:hover { color: var(--red); }
  .footer-copyright {
    margin: 0;
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--text-3);
  }

  .anim-setting {
    border: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: center;
    font-family: var(--font-hand);
    font-size: 18px;
    color: var(--text-2);
  }
  .anim-setting legend { padding: 0 8px 0 0; }
  .anim-setting label {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    cursor: pointer;
  }
</style>
