---
// Book card for a "coup de cœur" entry. Cover falls back to a typographic
// card (navy background, title + author) when the epagine image 404s.
import type { CollectionEntry } from 'astro:content';
import { epagineCoverUrl } from '../lib/epagine';

interface Props {
  entry: CollectionEntry<'coupsDeCoeur'>;
  flip?: boolean;
}

const { entry, flip = false } = Astro.props;
const d = entry.data;
const base = import.meta.env.BASE_URL;
const cover = d.couverture ? `${base}${d.couverture.replace(/^\//, '')}` : epagineCoverUrl(d.isbn13);
// Alido (librairies-occitanie.com) resolves /livre/{isbn13} straight to the
// book page of the shop's online store.
const alido = `https://www.librairies-occitanie.com/livre/${d.isbn13}`;
---
<article class:list={['book-card', { 'book-card--flip': flip }]}>
  <a
    class="cover"
    href={alido}
    target="_blank"
    rel="noopener"
    aria-label={`Commander « ${d.titre ?? ''} » sur Alido`}
  >
    <img
      src={cover}
      alt={`Couverture du livre ${d.titre ?? ''}`}
      loading="lazy"
      onerror="this.closest('.cover').classList.add('fallback')"
    />
    <div class="cover-fallback" aria-hidden="true">
      <strong>{d.titre}</strong>
      <span>{d.auteur}</span>
    </div>
  </a>
  <div class="book-meta">
    <h3 class="titre">{d.titre}</h3>
    <p class="auteur">{d.auteur} — {d.editeur}</p>
  </div>
  <p class="citation">« {d.citation} »</p>
</article>

<style>
  .book-card {
    background: var(--paper-card);
    border-radius: 8px;
    padding: 22px 22px 26px;
    box-shadow: 0 20px 42px rgba(24, 30, 50, 0.13);
    transform: rotate(-1.2deg);
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .book-card--flip {
    transform: rotate(1.4deg);
  }

  .cover {
    display: block;
    position: relative;
    width: 100%;
    height: 460px;
  }
  .cover img {
    width: 100%;
    height: 100%;
    display: block;
    /* Epagine covers have no single ratio (0.64–0.74 measured, squares
       possible for albums jeunesse) : show them whole on the card paper. */
    object-fit: contain;
    border-radius: 4px;
  }
  .cover-fallback {
    display: none;
    position: absolute;
    inset: 0;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 24px;
    text-align: center;
    background: var(--navy);
    border-radius: 4px;
  }
  .cover-fallback strong {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 24px;
    color: var(--paper);
  }
  .cover-fallback span {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 16px;
    color: var(--text-on-dark);
  }
  .cover.fallback img {
    display: none;
  }
  .cover.fallback .cover-fallback {
    display: flex;
  }

  .book-meta {
    display: flex;
    flex-direction: column;
  }
  .titre {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 24px;
    color: var(--ink);
  }
  .auteur {
    margin: 4px 0 0;
    font-family: var(--font-body);
    font-style: italic;
    font-size: 16px;
    color: var(--text-3);
  }
  .citation {
    margin: 0;
    font-family: var(--font-hand);
    font-size: 22px;
    line-height: 1.35;
    color: var(--navy);
  }

  @media (max-width: 720px) {
    .cover { height: 360px; }
  }
</style>
