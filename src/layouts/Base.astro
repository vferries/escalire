---
import { getEntry } from 'astro:content';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import cormorant600 from '@fontsource/cormorant-garamond/files/cormorant-garamond-latin-600-normal.woff2?url';

interface Props {
  title: string;
  description: string;
  /** page path under the base, e.g. 'mentions-legales/' — '' = home */
  path?: string;
}
const { title, description, path = '' } = Astro.props;
const infos = await getEntry('infos', 'infos');
const annonce = infos?.data.annonce ?? '';
const base = import.meta.env.BASE_URL;
const canonical = new URL(base + path, Astro.site).href;
const isHome = path === '';

// JSON-LD BookStore: opening hours derived from infos.horaires (schema.org day names,
// two specs per open day — morning and afternoon slot).
const jourSchema: Record<string, string> = {
  lundi: 'Monday', mardi: 'Tuesday', mercredi: 'Wednesday', jeudi: 'Thursday',
  vendredi: 'Friday', samedi: 'Saturday', dimanche: 'Sunday',
};
const toHM = (s: string) => s.replace(/(\d{2})h(\d{2})/, '$1:$2');
// international format for JSON-LD; same normalization as the tel: link in Infos.astro
const telephoneIntl = infos?.data.telephone
  ? `+33${infos.data.telephone.replace(/\D/g, '').replace(/^0/, '')}`
  : undefined;
const openingHours = Object.entries(infos?.data.horaires ?? {}).flatMap(([jour, h]) =>
  [h.matin, h.apresMidi].filter(Boolean).map((slot) => {
    const [opens, closes] = (slot as string).split(' – ').map(toHM);
    return {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: `https://schema.org/${jourSchema[jour]}`,
      opens, closes,
    };
  })
);
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BookStore',
  name: 'Librairie Escalire',
  url: canonical,
  image: new URL(`${base}assets/logo-escalire.png`, Astro.site).href,
  telephone: telephoneIntl,
  email: infos?.data.email,
  address: {
    '@type': 'PostalAddress',
    // last line of adresse.lignes is fixed as "31750 Escalquens"
    streetAddress: infos?.data.adresse.lignes.slice(0, -1).join(', '),
    postalCode: '31750',
    addressLocality: 'Escalquens',
    addressCountry: 'FR',
  },
  geo: { '@type': 'GeoCoordinates', latitude: infos?.data.adresse.lat, longitude: infos?.data.adresse.lng },
  openingHoursSpecification: openingHours,
  sameAs: [infos?.data.instagram, infos?.data.facebook].filter(Boolean),
};
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(`${base}assets/logo-escalire.png`, Astro.site).href} />
    <meta property="og:locale" content="fr_FR" />
    <meta name="twitter:card" content="summary" />
    {/* escape < so CMS-edited strings can never close the script tag */}
    {isHome && <script type="application/ld+json" set:html={JSON.stringify(jsonLd).replace(/</g, '\u003c')} />}
    <link rel="icon" href={`${base}favicon.png`} type="image/png" />
    <link rel="apple-touch-icon" href={`${base}apple-touch-icon.png`} />
    {/* fetchpriority must match the Hero <img>'s hint: the preload's own priority
       wins over the later <img>, and images preload at "Low" by default */}
    <link rel="preload" as="image" href={`${base}assets/logo-escalire.png`} fetchpriority="high" />
    <link rel="preload" as="font" type="font/woff2" href={cormorant600} crossorigin />
    <script is:inline>
      document.documentElement.dataset.intensite = matchMedia('(prefers-reduced-motion: reduce)').matches
        ? 'discret'
        : 'immersif';
    </script>
  </head>
  <body>
    <Nav />
    {annonce && <p class="annonce" role="status">{annonce}</p>}
    <slot />
    <Footer />
    <script src="../scripts/site.js"></script>
  </body>
</html>
<style>
  .annonce {
    margin: 0;
    margin-top: 63px; /* clears fixed nav: 12px+12px padding + 38px logo + 1px border */
    padding: 10px 20px;
    background: var(--navy);
    color: var(--paper);
    font-family: var(--font-hand);
    font-size: 20px;
    text-align: center;
  }
</style>
