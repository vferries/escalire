---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import TornEdge from '../components/TornEdge.astro';
import Librairie from '../components/Librairie.astro';
import CoupsDeCoeur from '../components/CoupsDeCoeur.astro';
import Rencontres from '../components/Rencontres.astro';
import Equipe from '../components/Equipe.astro';
import Infos from '../components/Infos.astro';
import { selectCoupsDeCoeurPublies } from '../lib/coupsDeCoeur';

// CoupsDeCoeur renders nothing with zero visible entries; its torn edge
// must disappear with it or two tears would stack on the night background.
const hasCoupsDeCoeur = selectCoupsDeCoeurPublies(await getCollection('coupsDeCoeur')).length > 0;
---
<Base
  title="Librairie Escalire — librairie indépendante à Escalquens"
  description="Librairie indépendante à Escalquens (Espace 61) : conseils de libraires, commandes dans la journée, rencontres d'auteurs et dédicaces."
>
  <Hero />
  <main>
    <TornEdge color="var(--paper)" />
    <Librairie />
    <TornEdge color="var(--night)" />
    <Rencontres />
    {hasCoupsDeCoeur && <TornEdge color="#e9f1f8" />}
    <CoupsDeCoeur />
    <TornEdge color="var(--paper)" />
    <Equipe />
    <Infos />
  </main>
</Base>
